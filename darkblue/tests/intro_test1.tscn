[sub_resource type="GDScript" id="GDScript_2ntwe"]
script/source = "extends Node
func _ready():
    var newsize = Vector2i(525, 350)
    get_window().content_scale_size = newsize
    if( DisplayServer.window_get_mode() == DisplayServer.WINDOW_MODE_WINDOWED ):
        get_window().size = newsize * 2
"

