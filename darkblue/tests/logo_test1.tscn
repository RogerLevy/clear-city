[sub_resource type="GDScript" id="GDScript_transition"]
script/source = "extends Node2D

func _ready():
    Input.set_mouse_mode(Input.MOUSE_MODE_HIDDEN)
    SceneLoader.preload_scene(\"res://darkblue/tests/title_test2.tscn\")
    SceneLoader.warmup_scene(\"res://darkblue/tests/wave_test5.tscn\")
    $AnimationPlayer.animation_finished.connect(_on_animation_finished)

func _on_animation_finished(anim_name):
    if anim_name == \"logos\":
        Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
        SceneLoader.change_scene(\"res://darkblue/tests/title_test2.tscn\")
"

