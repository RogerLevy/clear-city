[sub_resource type="GDScript" id="GDScript_5y6s7"]
script/source = "extends Node2D

func _ready():
    g.tri_manager = %TriManager
    g.playfield = %Playfield
    g.p1 = %Ship
    g.energy = 1000
    g._status_text = get_node_or_null(\"%EnergyStatusText\")
    var viewport = %PixelatedViewport/SubViewport/PlayfieldContainer
    g.playfield.reparent.call_deferred(viewport)
"

