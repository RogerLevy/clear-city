boot_splash/bg_color=Color(0.14117648, 0.79607844, 0.14117648, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"
run/main_scene.darkblue-inputlag-test=""
run/main_scene.darkblue-visuals-test="uid://ck2hs02t8xhpa"
