config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.14117648, 0.79607844, 0.14117648, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cu06v5awretns"
driver/mix_rate=48000
beat/default_timing_mode=2
beat/bpm=143.0
beat/metronome_enabled=true
beat/metronome_sample="uid://dcjio1vuxp1v"

[autoload]

beat="*uid://bp8vsqr2b5bjf"
g="*uid://5780chgktfwu"

[debug]

