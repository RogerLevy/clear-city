[display]

window/size/viewport_width=525
window/size/viewport_height=350
window/size/mode=3
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"
window/size/mode.editor=3
window/vsync/vsync_mode.editor=1

[editor]

movie_writer/video_quality=0.8
movie_writer/movie_file="C:/Users/roger/Desktop/coolstuff/darkblue-wavetest3-playtest.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/actor_factory/plugin.cfg", "res://addons/anim_track_converter/plugin.cfg", "res://addons/favorites/plugin.cfg", "res://addons/hide_bottom_panel_on_build/plugin.cfg", "res://addons/make_unique_anim/plugin.cfg", "res://addons/node_disabler/plugin.cfg", "res://addons/repl/plugin.cfg", "res://addons/sequence_editor/plugin.cfg", "res://addons/snap_rotate/plugin.cfg", "res://addons/solo_visibility/plugin.cfg")

